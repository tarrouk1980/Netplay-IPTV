generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  password          String
  name              String
  phone             String?
  role              Role           @default(BUYER)
  isVerified        Boolean        @default(false)
  subscriptionPlan  String         @default("FREE")
  subscriptionEnd   DateTime?
  loyaltyPoints     Int            @default(0)
  createdAt         DateTime       @default(now())
  products          Product[]
  services          Service[]
  orders            Order[]
  reviews           Review[]
  lives             LiveSession[]  @relation("VendorLives")
  favorites         Favorite[]
  notifications     Notification[]
  store             Store?
  sentMessages      Message[]      @relation("MessageSender")
  receivedMessages  Message[]      @relation("MessageReceiver")
  coupons           Coupon[]
  returnRequests    ReturnRequest[]
}

model Store {
  id          String   @id @default(uuid())
  sellerId    String   @unique
  seller      User     @relation(fields: [sellerId], references: [id])
  name        String
  description String?
  logo        String?
  cover       String?
  phone       String?
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

model Product {
  id            String        @id @default(uuid())
  title         String
  description   String
  price         Float
  promoPrice    Float?
  brand         String?
  specs         Json?
  images        String[]
  category      String
  stock         Int           @default(0)
  stockAlert    Int           @default(5)
  isActive      Boolean       @default(true)
  isBestSeller  Boolean       @default(false)
  isNewArrival  Boolean       @default(true)
  sellerId      String
  seller        User          @relation(fields: [sellerId], references: [id])
  createdAt     DateTime      @default(now())
  orderItems    OrderItem[]
  reviews       Review[]
  views         ProductView[]
  favorites     Favorite[]
  flashSales    FlashSale[]
}

model Service {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float
  category    String
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  reviews     Review[]
}

model Order {
  id              String          @id @default(uuid())
  buyerId         String
  buyer           User            @relation(fields: [buyerId], references: [id])
  items           OrderItem[]
  total           Float
  status          OrderStatus     @default(PENDING)
  paymentMethod   PaymentMethod
  deliveryAddress Json?
  couponCode      String?
  createdAt       DateTime        @default(now())
  returnRequests  ReturnRequest[]
}

model ReturnRequest {
  id          String       @id @default(uuid())
  orderId     String
  order       Order        @relation(fields: [orderId], references: [id])
  buyerId     String
  buyer       User         @relation(fields: [buyerId], references: [id])
  reason      String
  status      ReturnStatus @default(PENDING)
  adminNote   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  KONNECT
  PAYMEE
  CASH_ON_DELIVERY
  CARD
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model ProductView {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  userId    String?
  createdAt DateTime @default(now())
}

model SearchLog {
  id        String   @id @default(uuid())
  query     String
  userId    String?
  results   Int
  createdAt DateTime @default(now())
}

model LiveSession {
  id          String    @id @default(uuid())
  title       String
  vendorId    String
  vendor      User      @relation("VendorLives", fields: [vendorId], references: [id])
  isActive    Boolean   @default(true)
  viewerCount Int       @default(0)
  products    String[]
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])
  createdAt DateTime @default(now())
}

model Message {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("MessageSender", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("MessageReceiver", fields: [receiverId], references: [id])
  content     String
  isRead      Boolean  @default(false)
  productId   String?
  createdAt   DateTime @default(now())
}

model Coupon {
  id          String    @id @default(uuid())
  code        String    @unique
  discount    Float
  type        String    @default("PERCENT")
  minAmount   Float?
  maxUses     Int?
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  sellerId    String
  seller      User      @relation(fields: [sellerId], references: [id])
  createdAt   DateTime  @default(now())
}

model FlashSale {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  discount    Float
  startAt     DateTime
  endAt       DateTime
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
}
