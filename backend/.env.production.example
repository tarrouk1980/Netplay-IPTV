# =============================================================================
# EASYWAY — Variables d'environnement pour la production sur Render
# =============================================================================

# Fournies automatiquement par Render (ne pas remplir manuellement)
DATABASE_URL=
REDIS_URL=

# Générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Mapbox (optionnel au départ)
MAPBOX_TOKEN=

# Firebase FCM — notifications push (optionnel au départ)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Stripe — paiements (optionnel au départ)
STRIPE_SECRET_KEY=

# Twilio — OTP SMS (optionnel au départ)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# App
NODE_ENV=production
PORT=3000
