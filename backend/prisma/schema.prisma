datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  CLIENT
  CHAUFFEUR
  LIVREUR
  DEPANNEUR
  MARCHAND
  ADMIN
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
  NOT_REQUIRED
}

enum PlanType {
  DAILY
  DECOUVERTE
  SEMAINE
  MENSUEL
  PRO
}

enum OrderStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum ServiceType {
  TAXI
  SOS
  DELIVERY
  GROCERY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  EXHAUSTED
}

enum PaymentProvider {
  STRIPE
  ORANGE_MONEY
}

enum DisputeStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

model User {
  id           String    @id @default(cuid())
  name         String
  phone        String    @unique
  email        String?   @unique
  password     String?
  role         UserRole  @default(CLIENT)
  kycStatus    KycStatus @default(NOT_REQUIRED)
  fcmToken     String?
  kycDocuments String?   @default("{}")
  rating       Float?    @default(0)
  totalRides   Int?      @default(0)
  referralCode String?   @unique
  referredBy   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  walletBalance         Float     @default(0)
  loyaltyPoints         Int       @default(0)
  subscriptionActive    Boolean   @default(false)
  subscriptionExpiresAt DateTime?
  suspended             Boolean   @default(false)
  avgRating             Float     @default(0)

  subscription        Subscription[]
  vehicle             Vehicle[]
  merchant            Merchant?
  ordersAsClient      Order[]          @relation("ClientOrders")
  ordersAsProvider    Order[]          @relation("ProviderOrders")
  reviewsGiven        Review[]         @relation("ReviewerRelation")
  reviewsReceived     Review[]         @relation("TargetRelation")
  tipsGiven           Tip[]            @relation("TipFrom")
  tipsReceived        Tip[]            @relation("TipTo")
  disputes            Dispute[]        @relation("ReporterDisputes")
  insuranceContracts  InsuranceContract[]
  referralRewardsGiven  ReferralReward[] @relation("ReferrerRewards")
  referralRewardsReceived ReferralReward[] @relation("RefereeRewards")
  walletTransactions  WalletTransaction[]
  loyaltyTransactions LoyaltyTransaction[]
  reportsGiven        Report[]         @relation("ReporterReports")
  reportsReceived     Report[]         @relation("ReportedReports")
  backHomeRides       BackHomeRide[]
}

enum RewardType {
  PASS_DAY
}

model ReferralReward {
  id           String     @id @default(cuid())
  referrerId   String
  referrer     User       @relation("ReferrerRewards", fields: [referrerId], references: [id])
  refereeId    String
  referee      User       @relation("RefereeRewards", fields: [refereeId], references: [id])
  rewardType   RewardType @default(PASS_DAY)
  rewardAmount Int        @default(1)
  createdAt    DateTime   @default(now())
}

model Subscription {
  id             String             @id @default(cuid())
  providerId     String
  provider       User               @relation(fields: [providerId], references: [id])
  planType       PlanType
  ridesTotal     Int                @default(0)
  ridesConsumed  Int                @default(0)
  ridesRemaining Int                @default(0)
  startDate      DateTime?
  endDate        DateTime?
  expiresAt      DateTime
  amount         Decimal            @default(0)
  status         SubscriptionStatus @default(ACTIVE)
  autoRenew      Boolean            @default(false)
  createdAt      DateTime           @default(now())
}

model Order {
  id                   String      @id @default(cuid())
  clientId             String
  client               User        @relation("ClientOrders", fields: [clientId], references: [id])
  providerId           String?
  provider             User?       @relation("ProviderOrders", fields: [providerId], references: [id])
  serviceType          ServiceType
  status               OrderStatus @default(PENDING)
  originLat            Float
  originLng            Float
  originAddress        String?
  destinationLat       Float?
  destinationLng       Float?
  destinationAddress   String?
  price                Decimal?
  counterPrice         Float?
  finalPrice           Float?
  passConsumed         Boolean     @default(false)
  clientConfirmedAt    DateTime?
  providerConfirmedAt  DateTime?
  createdAt            DateTime    @default(now())
  completedAt          DateTime?

  events   OrderEvent[]
  reviews  Review[]
  tips     Tip[]
  disputes Dispute[]
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  eventType String
  payload   Json
  createdAt DateTime @default(now())
}

model Vehicle {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  make          String
  model         String
  plate         String   @unique
  vehicleType   String
  licenseNumber String?
  verified      Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Merchant {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id])
  name                 String
  category             String
  address              String
  priceAgreementSigned Boolean   @default(false)
  isBoosted            Boolean   @default(false)
  boostedUntil         DateTime?
  createdAt            DateTime  @default(now())

  products Product[]
  ads      Advertisement[]
}

model Product {
  id         String   @id @default(cuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  name       String
  category   String
  price      Decimal
  stock      Int      @default(0)
  imageUrl   String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model InsuranceContract {
  id           String   @id @default(cuid())
  companyName  String
  providerId   String
  provider     User     @relation(fields: [providerId], references: [id])
  quotaTotal   Int
  quotaUsed    Int      @default(0)
  amountFixed  Decimal
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model Dispute {
  id         String        @id @default(cuid())
  orderId    String
  order      Order         @relation(fields: [orderId], references: [id])
  reporterId String
  reporter   User          @relation("ReporterDisputes", fields: [reporterId], references: [id])
  reason     String
  status     DisputeStatus @default(OPEN)
  resolution String?
  createdAt  DateTime      @default(now())
  resolvedAt DateTime?
}

model Review {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  reviewerId String
  reviewer   User     @relation("ReviewerRelation", fields: [reviewerId], references: [id])
  targetId   String
  target     User     @relation("TargetRelation", fields: [targetId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
}

model Tip {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  amount     Decimal
  fromUserId String
  from       User     @relation("TipFrom", fields: [fromUserId], references: [id])
  toUserId   String
  to         User     @relation("TipTo", fields: [toUserId], references: [id])
  createdAt  DateTime @default(now())
}

enum AdType {
  BANNER_TOP
  BANNER_INLINE
  SPONSORED_CARD
  INTERSTITIAL
}

enum AdPlacement {
  HOME
  DELIVERY
  GROCERY
  TAXI
  ALL
}

model PassDiscount {
  id          String   @id @default(cuid())
  code        String   @unique
  label       String
  discountPct Int
  validFor    String[]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Advertisement {
  id          String      @id @default(uuid())
  title       String
  imageUrl    String
  targetUrl   String?
  type        AdType
  placement   AdPlacement
  merchantId  String?
  startDate   DateTime
  endDate     DateTime
  budgetTND   Decimal
  cpmRate     Decimal     @default(5.000)
  impressions Int         @default(0)
  clicks      Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  merchant    Merchant?   @relation(fields: [merchantId], references: [id])
}

model WalletTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  type        String   // RECHARGE | DEBIT | REFUND
  description String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  userId      String
  points      Int
  type        String   // EARN | REDEEM
  description String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Report {
  id          String    @id @default(cuid())
  reporterId  String
  reportedId  String
  orderId     String?
  reasons     String[]
  details     String    @default("")
  status      String    @default("PENDING") // PENDING | RESOLVED | DISMISSED
  adminNote   String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  reporter    User      @relation("ReporterReports", fields: [reporterId], references: [id])
  reported    User      @relation("ReportedReports", fields: [reportedId], references: [id])
}

model BackHomeRide {
  id          String   @id @default(cuid())
  driverId    String
  destLat     Float
  destLng     Float
  destAddress String   @default("")
  seatsTotal  Int      @default(1)
  seatsLeft   Int      @default(1)
  price       Float    @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  driver      User     @relation(fields: [driverId], references: [id])
}

// ─── HOTEL MODULE ───────────────────────────────────────────────────────────

enum HotelCategory {
  HOTEL
  RESORT
  APARTMENT
  HOSTEL
  VILLA
}

enum RoomType {
  SINGLE
  DOUBLE
  TWIN
  SUITE
  DELUXE
  FAMILY
}

enum PriceSource {
  BOOKING
  EXPEDIA
  HOTELS_COM
  AIRBNB
  DIRECT
}

enum TravelType {
  SOLO
  COUPLE
  FAMILY
  BUSINESS
}

model Hotel {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String
  address     String
  city        String
  country     String        @default("Tunisie")
  lat         Float
  lng         Float
  stars       Int
  category    HotelCategory @default(HOTEL)
  mainImage   String
  images      String[]
  amenities   String[]
  rating      Float         @default(0)
  reviewCount Int           @default(0)
  isActive    Boolean       @default(true)
  isFeatured  Boolean       @default(false)
  createdAt   DateTime      @default(now())

  rooms         HotelRoom[]
  priceOffers   HotelPriceOffer[]
  reviews       HotelReview[]
  favorites     HotelFavorite[]
}

model HotelRoom {
  id          String     @id @default(cuid())
  hotelId     String
  hotel       Hotel      @relation(fields: [hotelId], references: [id])
  name        String
  type        RoomType
  maxGuests   Int
  beds        Int
  bathrooms   Int        @default(1)
  size        Float?
  amenities   String[]
  images      String[]
  isAvailable Boolean    @default(true)

  priceOffers HotelPriceOffer[]
}

model HotelPriceOffer {
  id                 String      @id @default(cuid())
  hotelId            String
  hotel              Hotel       @relation(fields: [hotelId], references: [id])
  roomId             String?
  room               HotelRoom?  @relation(fields: [roomId], references: [id])
  sourceProvider     PriceSource
  originalPrice      Decimal
  discountedPrice    Decimal
  currency           String      @default("TND")
  checkIn            DateTime
  checkOut           DateTime
  guestsCount        Int
  availability       Int         @default(10)
  dealLabel          String?
  isFreeCancellation Boolean     @default(false)
  includesBreakfast  Boolean     @default(false)
  deepLink           String?
  lastUpdatedAt      DateTime    @default(now())
}

model HotelReview {
  id          String     @id @default(cuid())
  hotelId     String
  hotel       Hotel      @relation(fields: [hotelId], references: [id])
  userId      String?
  authorName  String
  rating      Float
  title       String?
  comment     String
  travelType  TravelType @default(COUPLE)
  pros        String[]
  cons        String[]
  stayDate    DateTime?
  createdAt   DateTime   @default(now())
}

model HotelFavorite {
  id        String   @id @default(cuid())
  userId    String
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, hotelId])
}

model HotelSearchLog {
  id           String   @id @default(cuid())
  userId       String?
  destination  String
  checkIn      DateTime?
  checkOut     DateTime?
  guestsCount  Int?
  filters      Json?
  resultsCount Int      @default(0)
  createdAt    DateTime @default(now())
}
